# Disable PHP execution inside the uploads folder for security
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|phps)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8
RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8

<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
