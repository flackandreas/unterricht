{% extends "base.twig" %}

{% block content %}
<div class="content-box" style="max-width: 500px; margin: 40px auto; padding: 30px;">
    <div style="text-align: center; margin-bottom: 25px;">
        <h2 style="color: var(--primary-color); border: none; padding: 0; margin-bottom: 5px;">Passwort ändern</h2>
        <p style="color: var(--text-muted); font-size: 0.9em;">Aus Sicherheitsgründen müssen Sie Ihr Passwort ändern, bevor Sie fortfahren können.</p>
    </div>

    <form method="POST" action="/change_password.php">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        
        <div class="form-group">
            <label for="current_password">Aktuelles Passwort:</label>
            <input type="password" id="current_password" name="current_password" required autofocus autocomplete="current-password">
        </div>

        <div class="form-group">
            <label for="new_password">Neues Passwort (min. 8 Zeichen):</label>
            <input type="password" id="new_password" name="new_password" required minlength="8" autocomplete="new-password">
        </div>

        <div class="form-group">
            <label for="new_password_confirm">Neues Passwort bestätigen:</label>
            <input type="password" id="new_password_confirm" name="new_password_confirm" required minlength="8" autocomplete="new-password">
        </div>

        <div style="margin-top: 25px;">
            <button type="submit" class="button-primary" style="width: 100%;">Passwort speichern</button>
        </div>
    </form>
</div>
{% endblock %}
