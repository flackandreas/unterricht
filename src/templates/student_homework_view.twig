<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auswertung: {{ sub.assignment_title }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
        :root {
            --primary-color: #2ecc71;
            --primary-dark: #27ae60;
            --bg-color: #f8fafc;
            --text-dark: #2c3e50;
            --border-color: #e2e8f0;
            --danger-color: #e74c3c;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-dark);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            min-height: 100vh;
        }
        .container {
            background-color: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            padding: 40px;
            width: 100%;
            max-width: 600px;
            margin-top: 20px;
            align-self: flex-start;
        }
        h1 { margin-top: 0; color: var(--primary-dark); font-size: 1.5rem; }
        .meta { color: #64748b; font-size: 0.9rem; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 1px solid var(--border-color); }
        .section-title { font-size: 1.1rem; font-weight: 600; margin: 25px 0 10px 0; color: #1e293b; }
        .feedback-box {
            background: #f0fdf4;
            padding: 20px;
            border-radius: 8px;
            border-left: 4px solid var(--primary-color);
            white-space: pre-wrap;
            line-height: 1.5;
            color: #1e293b;
            font-size: 0.95rem;
        }
        
        /* Bounding Box / Tooltip Overlay styles */
        .image-overlay-container {
            position: relative;
            display: inline-block;
            width: 100%;
            margin-top: 10px;
        }
        .error-box {
            position: absolute;
            border: 2px solid var(--danger-color);
            background: rgba(231, 76, 60, 0.15);
            cursor: help;
            transition: background 0.2s, border-color 0.2s;
            border-radius: 4px;
        }
        .error-box:hover {
            background: rgba(231, 76, 60, 0.3);
            border-color: #c0392b;
            z-index: 10;
        }
        .error-box::after {
            content: attr(data-description);
            position: absolute;
            bottom: 105%;
            left: 50%;
            transform: translateX(-50%);
            background: #2c3e50;
            color: white;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 0.85rem;
            line-height: 1.4;
            white-space: pre-wrap;
            width: max-content;
            max-width: 250px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.2s, visibility 0.2s;
            pointer-events: none;
            z-index: 100;
            font-weight: normal;
            font-family: 'Inter', sans-serif;
            text-align: left;
        }
        .error-box:hover::after {
            opacity: 1;
            visibility: visible;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Hausaufgabe: {{ sub.assignment_title }}</h1>
    <div class="meta">
        Klasse/Fach: <strong>{{ sub.klasse }} - {{ sub.fach }}</strong><br>
        Schüler: <strong>{{ sub.student_name }}</strong><br>
        Datum: <strong>{{ sub.created_at|date('d.m.Y H:i') }}</strong>
    </div>

    <!-- Gamification Header Widget -->
    <div class="gamification-header" style="display: flex; gap: 20px; align-items: center; background: linear-gradient(135deg, #1e293b, #0f172a); color: white; padding: 20px; border-radius: 12px; margin-bottom: 25px; box-shadow: 0 10px 25px rgba(15, 23, 42, 0.3); border: 1px solid rgba(255,255,255,0.05); overflow: hidden; position: relative;">
        <!-- Background light effect -->
        <div style="position: absolute; top: -50%; left: -20%; width: 60%; height: 200%; background: radial-gradient(circle, rgba(46, 204, 113, 0.15) 0%, transparent 60%); pointer-events: none;"></div>
        
        <!-- Avatar Container -->
        <div style="position: relative; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 8px;">
            <div style="position: relative;">
                <img id="gamification-avatar" src="https://api.dicebear.com/7.x/adventurer/svg?seed=placeholder" alt="Avatar" style="width: 75px; height: 75px; border-radius: 50%; background: #f1f5f9; border: 3px solid var(--primary-color); display: block; box-shadow: 0 4px 10px rgba(0,0,0,0.3);">
                <div id="gamification-level-badge" style="position: absolute; bottom: -5px; right: -5px; background: var(--primary-color); color: white; font-weight: bold; font-size: 0.75em; padding: 4px 8px; border-radius: 10px; border: 2px solid #0f172a; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">
                    Lvl <span id="gamification-level-num">1</span>
                </div>
            </div>
            <!-- Style Selector Dropdown -->
            <select id="gamification-avatar-style" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 4px; padding: 2px 6px; font-size: 0.7em; cursor: pointer; outline: none; max-width: 90px; text-align-last: center; font-weight: 500;">
                <option value="adventurer" style="background: #1e293b; color: white;">Abenteuer</option>
                <option value="bottts" style="background: #1e293b; color: white;">Roboter</option>
                <option value="fun-emoji" style="background: #1e293b; color: white;">Emoji</option>
                <option value="lorelei" style="background: #1e293b; color: white;">Comic</option>
                <option value="pixel-art" style="background: #1e293b; color: white;">Pixel-Art</option>
                <option value="croodles" style="background: #1e293b; color: white;">Monster</option>
            </select>
        </div>

        <!-- Progress and Details -->
        <div style="flex-grow: 1; min-width: 0;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                <span id="gamification-nickname" style="font-weight: 700; font-size: 1.1em; letter-spacing: 0.5px;">Student</span>
                <span style="font-size: 0.85em; color: #94a3b8; font-weight: 600;"><span id="gamification-xp-current">0</span> / 500 XP</span>
            </div>
            
            <!-- XP Progress Bar -->
            <div style="width: 100%; height: 10px; background: rgba(255,255,255,0.1); border-radius: 5px; overflow: hidden; margin-bottom: 10px;">
                <div id="gamification-xp-bar" style="width: 0%; height: 100%; background: linear-gradient(90deg, #2ecc71, #58d68d); transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1); border-radius: 5px;"></div>
            </div>
            
            <!-- Streak and Achievements -->
            <div style="display: flex; gap: 15px; font-size: 0.85em; color: #cbd5e1;">
                <div style="display: flex; align-items: center; gap: 4px;">
                    <span style="font-size: 1.1em;">🔥</span>
                    <strong style="color: #ff7675;"><span id="gamification-streak-num">1</span>er-Streak</strong>
                </div>
                <div style="display: flex; align-items: center; gap: 4px;">
                    <span>🏆</span>
                    <span>Level <span id="gamification-level-title">Novize</span></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Class Quest Widget -->
    {% if expected_submissions > 0 %}
        {% set percent = (actual_submissions / expected_submissions * 100)|round(0) %}
        {% if percent > 100 %}{% set percent = 100 %}{% endif %}
        <div class="class-quest-widget" style="background: #f8fafc; border: 1px solid var(--border-color); padding: 20px; border-radius: 12px; margin-bottom: 25px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                <span style="font-weight: 600; font-size: 0.95em; display: flex; align-items: center; gap: 6px;">
                    <span>🛡️</span>
                    <strong>Klassen-Quest: {{ sub.klasse }} - {{ sub.fach }}</strong>
                </span>
                <span style="font-size: 0.85em; font-weight: 700; color: var(--primary-dark);">{{ actual_submissions }} / {{ expected_submissions }} Abgaben ({{ percent }}%)</span>
            </div>
            
            <!-- Progress Bar -->
            <div style="width: 100%; height: 12px; background: #e2e8f0; border-radius: 6px; overflow: hidden; margin-bottom: 8px;">
                <div style="width: {{ percent }}%; height: 100%; background: linear-gradient(90deg, #3498db, #2ecc71); border-radius: 6px; transition: width 1s ease;"></div>
            </div>
            
            <p style="margin: 0; font-size: 0.85em; color: var(--text-dark); line-height: 1.4;">
                {% if percent >= 100 %}
                    <strong>Quest erfolgreich abgeschlossen! 🎉 Hervorragende Teamarbeit der ganzen Klasse!</strong>
                {% else %}
                    Gemeinsam stark: Es fehlen noch {{ expected_submissions - actual_submissions }} Abgaben, um die Quest abzuschließen!
                {% endif %}
            </p>
        </div>
    {% endif %}

    {% if sub.status == 'evaluated' %}
        <div class="section-title">Feedback für dich:</div>
        <div class="feedback-box">{{ sub.student_feedback }}</div>
        
        {% if sub.score is not null %}
            <div style="text-align: right; margin-top: 15px; font-weight: bold; font-size: 1.25em; color: var(--primary-dark);">
                Erreichte Punkte: {{ sub.score }} / 100
            </div>
        {% endif %}

        {% if sub.image_path %}
            <div class="section-title">Markierte Fehler im Bild (Fahre mit der Maus über die roten Boxen):</div>
            <div class="image-overlay-container">
                <img src="/{{ sub.image_path }}" style="width: 100%; display: block; border-radius: 8px; border: 1px solid var(--border-color);" alt="Hausaufgabe">
                
                {% if sub.error_markers is not empty %}
                    {% set markers = sub.error_markers|json_decode %}
                    {% for marker in markers %}
                        {% set ymin = marker.box_2d[0] / 10 %}
                        {% set xmin = marker.box_2d[1] / 10 %}
                        {% set ymax = marker.box_2d[2] / 10 %}
                        {% set xmax = marker.box_2d[3] / 10 %}
                        {% set height = ymax - ymin %}
                        {% set width = xmax - xmin %}
                        <div class="error-box" 
                             style="position: absolute; top: {{ ymin }}%; left: {{ xmin }}%; width: {{ width }}%; height: {{ height }}%;"
                             data-description="{{ marker.description }}">
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        {% endif %}
    {% else %}
        <div style="text-align: center; padding: 40px; background: #fffbeb; border: 1px solid #fef3c7; border-radius: 8px; color: #b45309;">
            <div style="font-size: 2em; margin-bottom: 10px;">⏳</div>
            <h3 style="margin: 0 0 10px 0;">Auswertung ausstehend</h3>
            <p style="margin: 0; font-size: 0.95em;">Deine Hausaufgabe wurde hochgeladen, aber die Bewertung läuft noch. Bitte lade diese Seite in ein paar Sekunden neu.</p>
        </div>
    {% endif %}
</div>

<!-- Gamification Engine -->
<script>
    window.subToken = "{{ sub.token|default('') }}";
    window.subScore = {{ sub.score|default('null') }};
    window.subStatus = "{{ sub.status }}";
    window.studentName = "{{ sub.student_name|default('') }}";

    document.addEventListener('DOMContentLoaded', () => {
        const state = {
            xp: parseInt(localStorage.getItem('student_xp') || '0'),
            level: parseInt(localStorage.getItem('student_level') || '1'),
            streak: parseInt(localStorage.getItem('student_streak') || '1'),
            last_sub_date: localStorage.getItem('student_last_sub_date') || null,
            nickname: localStorage.getItem('student_nickname') || null,
            avatar_seed: localStorage.getItem('student_avatar_seed') || null,
            style: localStorage.getItem('student_avatar_style') || 'adventurer',
            rewarded_subs: JSON.parse(localStorage.getItem('student_rewarded_subs') || '[]')
        };

        // Update Nickname and Avatar Seed with entered name if available
        if (window.studentName && window.studentName !== '') {
            state.nickname = window.studentName;
            localStorage.setItem('student_nickname', state.nickname);
            state.avatar_seed = window.studentName;
            localStorage.setItem('student_avatar_seed', state.avatar_seed);
        } else if (!state.nickname) {
            const prefixes = ["Cleverer", "Flinker", "Neugieriger", "Schlauer", "Fleißiger", "Kreativer", "Schneller"];
            const suffixes = ["Fuchs", "Wolf", "Koala", "Biber", "Igel", "Löwe", "Falke"];
            const randomPrefix = prefixes[Math.floor(Math.random() * prefixes.length)];
            const randomSuffix = suffixes[Math.floor(Math.random() * suffixes.length)];
            const randNum = Math.floor(Math.random() * 90) + 10;
            state.nickname = `${randomPrefix}_${randomSuffix}_${randNum}`;
            localStorage.setItem('student_nickname', state.nickname);
        }

        // Initialize Avatar
        if (!state.avatar_seed) {
            state.avatar_seed = Math.random().toString(36).substring(2, 10);
            localStorage.setItem('student_avatar_seed', state.avatar_seed);
        }

        // Initialize Avatar Style Selection Dropdown
        const styleSelect = document.getElementById('gamification-avatar-style');
        if (styleSelect) {
            styleSelect.value = state.style;
            styleSelect.addEventListener('change', function() {
                state.style = this.value;
                localStorage.setItem('student_avatar_style', state.style);
                updateUI();
            });
        }

        // Check for new XP rewards
        if (window.subToken && window.subStatus === 'evaluated' && !state.rewarded_subs.includes(window.subToken)) {
            let earnedXp = 100; // Base XP for submission
            let scoreXp = 0;
            if (window.subScore !== null && !isNaN(window.subScore)) {
                scoreXp = Math.round(window.subScore * 2);
                earnedXp += scoreXp;
            }

            // Streak calculations
            const now = new Date();
            let streakBonus = 0;
            if (state.last_sub_date) {
                const lastDate = new Date(state.last_sub_date);
                const diffTime = Math.abs(now - lastDate);
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                if (diffDays >= 1 && diffDays <= 7) {
                    state.streak += 1;
                    streakBonus = state.streak * 20;
                    earnedXp += streakBonus;
                } else if (diffDays > 7) {
                    state.streak = 1;
                }
            } else {
                state.streak = 1;
            }
            state.last_sub_date = now.toISOString();

            // Leveling check
            const oldLevel = state.level;
            state.xp += earnedXp;
            state.level = Math.floor(state.xp / 500) + 1;

            state.rewarded_subs.push(window.subToken);

            // Save state
            localStorage.setItem('student_xp', state.xp.toString());
            localStorage.setItem('student_level', state.level.toString());
            localStorage.setItem('student_streak', state.streak.toString());
            localStorage.setItem('student_last_sub_date', state.last_sub_date);
            localStorage.setItem('student_rewarded_subs', JSON.stringify(state.rewarded_subs));

            // Render details
            let alertHtml = `<div style="text-align: left; font-size: 0.95em; line-height: 1.5; color: #1e293b;">
                <p>Du hast <strong>+${earnedXp} XP</strong> erhalten:</p>
                <ul style="margin: 5px 0; padding-left: 20px;">
                    <li>+100 XP (Standardabgabe)</li>`;
            if (scoreXp > 0) alertHtml += `<li>+${scoreXp} XP (Punkte-Bonus: ${window.subScore}/100)</li>`;
            if (streakBonus > 0) alertHtml += `<li>+${streakBonus} XP (${state.streak}er-Streak-Bonus! 🔥)</li>`;
            alertHtml += `</ul></div>`;

            setTimeout(() => {
                if (state.level > oldLevel) {
                    // Confetti effect
                    if (typeof confetti === 'function') {
                        confetti({
                            particleCount: 150,
                            spread: 80,
                            origin: { y: 0.6 }
                        });
                    }
                    Swal.fire({
                        title: 'LEVEL UP! 🎉',
                        html: `<h3 style="color: var(--primary-dark); margin: 5px 0 15px 0;">Level ${state.level} erreicht!</h3>` + alertHtml,
                        icon: 'success',
                        confirmButtonText: 'Genial!'
                    });
                } else {
                    Swal.fire({
                        title: 'XP gesammelt! 🌟',
                        html: alertHtml,
                        icon: 'success',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 5000
                    });
                }
            }, 500);
        }

        // Render UI
        function updateUI() {
            const nicknameElem = document.getElementById('gamification-nickname');
            if (nicknameElem) nicknameElem.innerText = state.nickname;

            const currentXpElem = document.getElementById('gamification-xp-current');
            if (currentXpElem) currentXpElem.innerText = state.xp % 500;

            const levelNumElem = document.getElementById('gamification-level-num');
            if (levelNumElem) levelNumElem.innerText = state.level;

            const streakNumElem = document.getElementById('gamification-streak-num');
            if (streakNumElem) streakNumElem.innerText = state.streak;

            const xpBarElem = document.getElementById('gamification-xp-bar');
            if (xpBarElem) {
                const percent = ((state.xp % 500) / 500) * 100;
                xpBarElem.style.width = percent + '%';
            }

            const avatarElem = document.getElementById('gamification-avatar');
            if (avatarElem && state.avatar_seed) {
                avatarElem.src = `https://api.dicebear.com/7.x/${state.style}/svg?seed=${state.avatar_seed}`;
            }

            const levelTitleElem = document.getElementById('gamification-level-title');
            if (levelTitleElem) {
                let title = "Novize";
                if (state.level >= 3) title = "Lehrling";
                if (state.level >= 5) title = "Forscher";
                if (state.level >= 7) title = "Experte";
                if (state.level >= 9) title = "Meister";
                if (state.level >= 11) title = "Großmeister";
                levelTitleElem.innerText = title;
            }
        }

        updateUI();
    });
</script>
</body>
</html>
