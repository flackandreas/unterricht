<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ assignment.title }} - Hausaufgabe Einreichen</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2ecc71;
            --primary-dark: #27ae60;
            --bg-color: #f8fafc;
            --text-dark: #2c3e50;
            --border-color: #e2e8f0;
            --danger-color: #e74c3c;
        }
        
        /* Bounding Box / Tooltip Overlay styles */
        .image-overlay-container {
            position: relative;
            display: inline-block;
            width: 100%;
        }
        .error-box {
            position: absolute;
            border: 2px solid var(--danger-color);
            background: rgba(231, 76, 60, 0.15);
            cursor: help;
            transition: background 0.2s, border-color 0.2s;
            border-radius: 4px;
        }
        .error-box:hover {
            background: rgba(231, 76, 60, 0.3);
            border-color: #c0392b;
            z-index: 10;
        }
        .error-box::after {
            content: attr(data-description);
            position: absolute;
            bottom: 105%;
            left: 50%;
            transform: translateX(-50%);
            background: #2c3e50;
            color: white;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 0.85rem;
            line-height: 1.4;
            white-space: pre-wrap;
            width: max-content;
            max-width: 250px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.2s, visibility 0.2s;
            pointer-events: none;
            z-index: 100;
            font-weight: normal;
            font-family: 'Inter', sans-serif;
            text-align: left;
        }
        .error-box:hover::after {
            opacity: 1;
            visibility: visible;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-dark);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            min-height: 100vh;
        }
        .container {
            background-color: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            padding: 40px;
            width: 100%;
            max-width: 600px;
            margin-top: 40px;
            align-self: flex-start;
        }
        h1 { margin-top: 0; color: var(--primary-dark); font-size: 1.5rem; }
        .meta { color: #64748b; font-size: 0.9rem; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--border-color); }
        .form-group { margin-bottom: 20px; }
        label { display: block; font-weight: 500; margin-bottom: 8px; }
        input[type="text"], input[type="file"] {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            box-sizing: border-box;
            font-family: inherit;
        }
        input[type="file"] {
            padding: 10px;
            background: #f8fafc;
            cursor: pointer;
        }
        button {
            width: 100%;
            padding: 14px;
            background-color: var(--primary-color);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        button:hover {
            background-color: var(--primary-dark);
        }
        .alert {
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 20px;
        }
        .alert-error { background-color: #fee2e2; color: #991b1b; border: 1px solid #f87171; }
        .alert-success { background-color: #dcfce7; color: #166534; border: 1px solid #86efac; }
        
        .loading { display: none; text-align: center; margin-top: 20px; }
        .spinner {
            border: 4px solid rgba(0, 0, 0, 0.1);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border-left-color: var(--primary-color);
            animation: spin 1s linear infinite;
            margin: 0 auto 15px auto;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

<div class="container">
    <h1>{{ assignment.title }}</h1>
    <div class="meta">{{ assignment.klasse }} - {{ assignment.fach }}</div>

    {% if error %}
        <div class="alert alert-error">{{ error }}</div>
    {% endif %}

    {% if result %}
        <div class="alert alert-success" style="margin-bottom: 25px;">
            <h3 style="margin-top: 0; color: #166534;">Hausaufgabe eingereicht!</h3>
            <p>Danke für deine Einreichung. Die Auswertung ist fertig!</p>
            
            <div style="margin-top: 15px; padding: 12px; background: rgba(255,255,255,0.75); border-radius: 6px; font-size: 0.85em; color: #166534; border: 1px dashed #86efac; display: flex; align-items: center; justify-content: space-between; gap: 10px;">
                <span style="word-break: break-all;">
                    <strong>Dein Ergebnis-Link:</strong><br>
                    <a id="view-link" href="/student_homework.php?view={{ result.token }}" target="_blank" style="text-decoration: underline; color: #166534; font-weight: 600;">
                        {{ host_url }}/student_homework.php?view={{ result.token }}
                    </a>
                </span>
                <button type="button" onclick="copyLink()" style="width: auto; padding: 6px 12px; font-size: 0.85em; background: var(--primary-dark); color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600; flex-shrink: 0;">Kopieren</button>
            </div>
        </div>
        
        <div style="margin-bottom: 25px;">
            <h4 style="margin-bottom: 8px;">Feedback für dich:</h4>
            <div style="background: #f0fdf4; padding: 20px; border-radius: 8px; border-left: 4px solid var(--primary-color); white-space: pre-wrap; line-height: 1.5; color: #1e293b;">{{ result.student_feedback }}</div>
        </div>
        
        {% if result.score is not null %}
            <div style="text-align: right; margin-top: 15px; margin-bottom: 30px; font-weight: bold; font-size: 1.2em; color: var(--primary-dark);">
                Erreichte Punkte: {{ result.score }} / 100
            </div>
        {% endif %}

        {% if result.image_path %}
            <div style="margin-top: 30px; margin-bottom: 20px;">
                <h4 style="margin-top: 0; margin-bottom: 10px; color: var(--text-dark);">Markierte Fehler im Bild (Bewege die Maus über die roten Boxen):</h4>
                <div class="image-overlay-container">
                    <img src="/{{ result.image_path }}" style="width: 100%; display: block; border-radius: 8px; border: 1px solid var(--border-color);" alt="Hausaufgabe">
                    
                    {% for marker in result.errors %}
                        {% set ymin = marker.box_2d[0] / 10 %}
                        {% set xmin = marker.box_2d[1] / 10 %}
                        {% set ymax = marker.box_2d[2] / 10 %}
                        {% set xmax = marker.box_2d[3] / 10 %}
                        {% set height = ymax - ymin %}
                        {% set width = xmax - xmin %}
                        <div class="error-box" 
                             style="position: absolute; top: {{ ymin }}%; left: {{ xmin }}%; width: {{ width }}%; height: {{ height }}%;"
                             data-description="{{ marker.description }}">
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <script>
            function copyLink() {
                const link = document.getElementById('view-link').href;
                navigator.clipboard.writeText(link).then(() => {
                    alert('Ergebnis-Link wurde in die Zwischenablage kopiert!');
                }).catch(err => {
                    // Fallback copy
                    const tempInput = document.createElement('input');
                    tempInput.value = link;
                    document.body.appendChild(tempInput);
                    tempInput.select();
                    document.execCommand('copy');
                    document.body.removeChild(tempInput);
                    alert('Ergebnis-Link wurde in die Zwischenablage kopiert!');
                });
            }
        </script>
    {% else %}
        <p style="margin-bottom: 25px;">Bitte trage deinen Namen ein und lade ein Foto deiner Hausaufgabe hoch. Die Auswertung dauert ca. 10-20 Sekunden.</p>
        
        <form action="" method="POST" enctype="multipart/form-data" id="uploadForm" onsubmit="showLoading()">
            <div class="form-group">
                <label for="student_name">Dein Vor- und Nachname</label>
                <input type="text" id="student_name" name="student_name" required placeholder="z.B. Max Mustermann">
            </div>
            
            <div class="form-group" style="margin-bottom: 30px;">
                <label for="homework_image">Foto der Hausaufgabe (JPG, PNG)</label>
                <input type="file" id="homework_image" name="homework_image" accept="image/jpeg, image/png, image/webp" capture="environment" required>
            </div>
            
            <button type="submit" id="submitBtn">Hochladen & Auswerten lassen</button>
            
            <div class="loading" id="loadingSection">
                <div class="spinner"></div>
                <div style="color: #64748b; font-weight: 500;">Die KI analysiert deine Hausaufgabe...<br><small>Bitte schließe diese Seite nicht.</small></div>
            </div>
        </form>

        <script>
            function showLoading() {
                document.getElementById('submitBtn').style.display = 'none';
                document.getElementById('loadingSection').style.display = 'block';
            }
        </script>
    {% endif %}
</div>

</body>
</html>
