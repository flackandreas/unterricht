{% extends "base.twig" %}

{% block extra_head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
{% endblock %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
        <h1>📈 Trend-Analyse</h1>
        <p style="color: var(--text-muted);">Verlauf der Unterrichts- und Klima-Bewertungen über die Zeit.</p>
    </div>
</div>

<div class="content-box" style="margin-bottom: 30px;">
    <form method="GET" style="display: flex; gap: 15px; align-items: flex-end;">
        <div class="form-group" style="margin: 0;">
            <label for="filter-klasse" style="display: block; margin-bottom: 5px; font-size: 0.9em;">Klasse Filtern</label>
            <select id="filter-klasse" name="klasse" style="padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                <option value="">Alle Klassen</option>
                {% for k in unique_classes %}
                    <option value="{{ k }}" {{ current_klasse == k ? 'selected' : '' }}>{{ k }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="form-group" style="margin: 0;">
            <label for="filter-fach" style="display: block; margin-bottom: 5px; font-size: 0.9em;">Fach Filtern</label>
            <select id="filter-fach" name="fach" style="padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                <option value="">Alle Fächer</option>
                {% for s in unique_subjects %}
                    <option value="{{ s }}" {{ current_fach == s ? 'selected' : '' }}>{{ s }}</option>
                {% endfor %}
            </select>
        </div>
        <button type="submit" class="btn" style="background-color: var(--primary-color); color: white; border: none; padding: 11px 25px; border-radius: 4px; cursor: pointer;">Filtern</button>
        <a href="/feedback_trends.php" style="padding: 11px 15px; text-decoration: none; color: var(--text-muted);">Reset</a>
    </form>
</div>

{% if grouped_history is empty %}
    <div class="content-box" style="margin-bottom: 30px;">
        <p style="text-align: center; color: var(--text-muted); padding: 40px 0; margin: 0;">Keine Trend-Daten für den ausgewählten Zeitraum oder Filter vorhanden.</p>
    </div>
{% else %}
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 500px), 1fr)); gap: 20px; margin-bottom: 30px;">
        {% for group_name, group in grouped_history %}
            <div class="content-box" style="margin-bottom: 0;">
                <h3>📈 Stimmungs-Barometer: {{ group_name }}</h3>
                <div style="height: 350px; margin-top: 20px; position: relative;">
                    <canvas id="trendChart_{{ loop.index }}"></canvas>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}

<div class="content-box" style="margin-top: 30px;">
    <h3>Letzte Sitzungen</h3>
    <table style="width: 100%; border-collapse: collapse; margin-top: 15px;">
        <thead>
            <tr style="text-align: left; border-bottom: 2px solid #eee;">
                <th style="padding: 10px;">Datum</th>
                <th style="padding: 10px;">Klasse/Fach</th>
                <th style="padding: 10px;">Fragen & Durchschnittswerte</th>
                <th style="padding: 10px;">Aktion</th>
            </tr>
        </thead>
        <tbody>
            {% for s in history|reverse %}
                <tr style="border-bottom: 1px solid #f9f9f9;">
                    <td style="padding: 10px;">{{ s.created_at|date('d.m.y') }}</td>
                    <td style="padding: 10px;">{{ s.klasse }} ({{ s.fach }})</td>
                    <td style="padding: 10px;">
                        {% for q in s.questions %}
                            <div style="font-size: 0.85em; margin-bottom: 4px;">
                                <span style="font-weight: 600; color: var(--primary-color);">{{ q.avg|number_format(1) }}</span> 
                                <span style="color: var(--text-muted);">{{ q.text }}</span>
                            </div>
                        {% endfor %}
                    </td>
                    <td style="padding: 10px;">
                        <a href="/feedback_view.php?id={{ s.id }}" style="text-decoration: none; font-size: 0.9em; color: var(--primary-color);">Details →</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block extra_scripts %}
<script>
document.addEventListener("DOMContentLoaded", function() {
    const colors = ['#4a90e2', '#27ae60', '#f39c12', '#9b59b6', '#e74c3c'];

    {% for group_name, group in grouped_history %}
    (function() {
        const ctx = document.getElementById('trendChart_{{ loop.index }}');
        if (!ctx) return;

        const labels = [
            {% for s in group.sessions %}
                '{{ s.created_at|date('d.m.') }}',
            {% endfor %}
        ];

        // Data structure to hold scores per question text
        const datasetsMap = {};
        {% for s in group.sessions %}
            {% set session_index = loop.index0 %}
            {% for q in s.questions %}
                if (!datasetsMap['{{ q.text|escape('js') }}']) {
                    datasetsMap['{{ q.text|escape('js') }}'] = new Array({{ group.sessions|length }}).fill(null);
                }
                datasetsMap['{{ q.text|escape('js') }}'][{{ session_index }}] = {{ q.avg is not null ? q.avg : 'null' }};
            {% endfor %}
        {% endfor %}

        const datasets = Object.keys(datasetsMap).map((text, index) => {
            return {
                label: text,
                data: datasetsMap[text],
                borderColor: colors[index % colors.length],
                backgroundColor: colors[index % colors.length],
                tension: 0.3,
                pointRadius: 5
            };
        });

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: datasets
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        min: 1,
                        max: 5,
                        ticks: {
                            callback: function(value) {
                                const labels = {1: '😫', 2: '🙁', 3: '😐', 4: '🙂', 5: '😄'};
                                return labels[value] || value;
                            }
                        }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y.toFixed(1);
                            }
                        }
                    }
                }
            }
        });
    })();
    {% endfor %}
});
</script>
{% endblock %}
