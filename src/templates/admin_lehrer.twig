{% extends "base.twig" %}

{% block content %}
<div class="content-box">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="margin: 0;">👥 Lehrerverwaltung</h2>
        <button class="btn btn-primary" onclick="openModal()" style="background-color: var(--primary-color); color: white; border: none; padding: 10px 15px; border-radius: 4px; cursor: pointer; font-weight: 600;">+ Neu anlegen</button>
    </div>

    {% if teachers|length == 0 %}
        <p style="color: var(--text-muted);">Keine Lehrkräfte gefunden.</p>
    {% else %}
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 2px solid #eee;">
                        <th style="padding: 12px 10px; color: var(--text-muted); font-size: 0.9em; width: 20%;">Kürzel</th>
                        <th style="padding: 12px 10px; color: var(--text-muted); font-size: 0.9em; width: 30%;">Name</th>
                        <th style="padding: 12px 10px; color: var(--text-muted); font-size: 0.9em; width: 25%;">E-Mail</th>
                        <th style="padding: 12px 10px; color: var(--text-muted); font-size: 0.9em; width: 10%;">Admin</th>
                        <th style="padding: 12px 10px; color: var(--text-muted); font-size: 0.9em; text-align: right; width: 15%;">Aktion</th>
                    </tr>
                </thead>
                <tbody>
                    {% for t in teachers %}
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 12px 10px; font-weight: 600;">{{ t.kuerzel }}</td>
                            <td style="padding: 12px 10px;">{{ t.name }}</td>
                            <td style="padding: 12px 10px;">{{ t.email ?: '—' }}</td>
                            <td style="padding: 12px 10px;">
                                {% if t.is_admin %}
                                    <span class="badge" style="background-color: var(--primary-color); color: white; padding: 3px 6px; font-size: 0.75em; border-radius: 4px;">Ja</span>
                                {% else %}
                                    <span style="color: var(--text-muted);">Nein</span>
                                {% endif %}
                            </td>
                            <td style="padding: 12px 10px; text-align: right;">
                                <button type="button" class="button-primary btn-edit" style="background-color: var(--primary-color); padding: 5px 10px; font-size: 0.85em; margin-right: 5px; color: white; border: none; border-radius: 4px; cursor: pointer;" title="Bearbeiten" 
                                    data-id="{{ t.id }}" 
                                    data-kuerzel="{{ t.kuerzel }}" 
                                    data-name="{{ t.name }}" 
                                    data-email="{{ t.email }}" 
                                    data-admin="{{ t.is_admin }}">✎</button>
                                
                                <form method="POST" style="display:inline-block; margin:0;" class="delete-form">
                                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                    <input type="hidden" name="action" value="delete">
                                    <input type="hidden" name="id" value="{{ t.id }}">
                                    <button type="button" class="button-danger btn-delete" style="background-color: var(--danger-color); padding: 5px 10px; font-size: 0.85em; color: white; border: none; border-radius: 4px; cursor: pointer;" title="Löschen" {% if t.id == app.session.user_id %}disabled{% endif %}>✖</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <!-- CSV Import Section -->
    <div style="margin-top: 40px; border-top: 1px solid #eee; padding-top: 30px;">
        <h3 style="margin-top: 0; margin-bottom: 15px;">📥 Lehrkräfte importieren (CSV)</h3>
        <p style="color: var(--text-muted); font-size: 0.9em; margin-bottom: 20px;">
            Laden Sie eine Semikolon-getrennte CSV-Datei hoch (Format: <code>Kürzel;Name;Email</code>). 
            Die erste Zeile wird als Überschrift ignoriert. Bereits bestehende Kürzel werden übersprungen.<br>
            Das Standard-Passwort für neu importierte Lehrkräfte lautet: <strong>Start123!</strong>
        </p>
        
        <form method="POST" enctype="multipart/form-data" style="display: flex; align-items: center; gap: 15px; background: #f9f9f9; padding: 20px; border-radius: 6px; border: 1px dashed #ccc;">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="action" value="import_csv">
            
            <input type="file" name="csv_file" accept=".csv" required style="flex-grow: 1;">
            
            <button type="submit" class="btn btn-primary" style="background-color: var(--primary-color); color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer; font-weight: 600;">Importieren</button>
        </form>
    </div>
</div>

<!-- Modal -->
<div id="lehrerModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: white; padding: 30px; border-radius: 8px; width: 100%; max-width: 500px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
        <h3 id="modalTitle" style="margin-top: 0;">Lehrkraft anlegen</h3>
        <form method="POST" id="lehrerForm">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="action" id="formAction" value="create">
            <input type="hidden" name="id" id="formId" value="">
            
            <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: 600; margin-bottom: 5px;">Kürzel *</label>
                <input type="text" name="kuerzel" id="formKuerzel" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
            </div>
            
            <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: 600; margin-bottom: 5px;">Vollständiger Name *</label>
                <input type="text" name="name" id="formName" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
            </div>
            
            <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: 600; margin-bottom: 5px;">E-Mail</label>
                <input type="email" name="email" id="formEmail" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
            </div>
            
            <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: 600; margin-bottom: 5px;">Passwort <span id="pwHint" style="font-weight: normal; font-size: 0.85em; color: var(--text-muted);">(Leer lassen, um nicht zu ändern)</span></label>
                <input type="password" name="password" id="formPassword" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
            </div>
            
            <div style="margin-bottom: 25px;">
                <label style="display: flex; align-items: center; font-weight: 600; cursor: pointer;">
                    <input type="checkbox" name="is_admin" id="formAdmin" value="1" style="margin-right: 10px; cursor: pointer;">
                    Administrator-Rechte gewähren
                </label>
            </div>
            
            <div style="text-align: right;">
                <button type="button" onclick="closeModal()" style="background: transparent; color: #333; border: 1px solid #ccc; padding: 10px 15px; border-radius: 4px; cursor: pointer; margin-right: 10px;">Abbrechen</button>
                <button type="submit" class="btn btn-primary" style="background-color: var(--primary-color); color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer; font-weight: 600;">Speichern</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const modal = document.getElementById('lehrerModal');
    
    function openModal() {
        document.getElementById('modalTitle').textContent = 'Lehrkraft anlegen';
        document.getElementById('formAction').value = 'create';
        document.getElementById('formId').value = '';
        document.getElementById('formKuerzel').value = '';
        document.getElementById('formName').value = '';
        document.getElementById('formEmail').value = '';
        document.getElementById('formAdmin').checked = false;
        document.getElementById('formPassword').required = true;
        document.getElementById('pwHint').style.display = 'none';
        
        modal.style.display = 'flex';
    }

    function closeModal() {
        modal.style.display = 'none';
    }

    // Close on background click
    modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });

    // Handle Edit Buttons
    document.querySelectorAll('.btn-edit').forEach(btn => {
        btn.addEventListener('click', function() {
            document.getElementById('modalTitle').textContent = 'Lehrkraft bearbeiten';
            document.getElementById('formAction').value = 'update';
            document.getElementById('formId').value = this.dataset.id;
            document.getElementById('formKuerzel').value = this.dataset.kuerzel;
            document.getElementById('formName').value = this.dataset.name;
            document.getElementById('formEmail').value = this.dataset.email;
            document.getElementById('formAdmin').checked = this.dataset.admin === '1';
            
            document.getElementById('formPassword').required = false;
            document.getElementById('formPassword').value = '';
            document.getElementById('pwHint').style.display = 'inline';
            
            modal.style.display = 'flex';
        });
    });

    // Handle Delete Buttons
    document.querySelectorAll('.btn-delete').forEach(btn => {
        btn.addEventListener('click', function() {
            if (this.disabled) return;
            const form = this.closest('form');
            Swal.fire({
                title: 'Lehrkraft löschen?',
                text: "Dies kann nicht rückgängig gemacht werden. Damit könnten auch verknüpfte Anträge und Feedback-Daten verloren gehen (falls die Datenbank-Konstraints das zulassen).",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: 'var(--danger-color)',
                cancelButtonColor: '#aaa',
                confirmButtonText: 'Ja, unwiderruflich löschen',
                cancelButtonText: 'Abbrechen'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });
    });
</script>
{% endblock %}
