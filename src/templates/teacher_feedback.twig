{% extends "base.twig" %}

{% block extra_head %}
<style>
    .qr-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.85);
        backdrop-filter: blur(5px);
        justify-content: center;
        align-items: center;
        cursor: zoom-out;
        transition: all 0.3s ease;
    }
    .qr-modal-content {
        background-color: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        text-align: center;
        max-width: 90%;
        max-height: 90%;
        transform: scale(0.8);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .qr-modal.active {
        display: flex;
    }
    .qr-modal.active .qr-modal-content {
        transform: scale(1);
    }
    .qr-large {
        width: 100%;
        max-width: 500px;
        height: auto;
        border: 15px solid white;
    }
    .close-modal {
        position: absolute;
        top: 20px;
        right: 30px;
        color: white;
        font-size: 40px;
        font-weight: bold;
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
    }
</style>
{% endblock %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h2>Schüler-Feedback (Live-Session)</h2>
    <a href="/index.php" class="btn" style="border: 1px solid var(--border-color); color: var(--text-dark); padding: 8px 16px; border-radius: 6px; text-decoration: none;">&larr; Zurück</a>
</div>

<div class="content-box" style="border-top: 4px solid var(--primary-color);">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
        <div>
            <h2 style="margin-top: 0;">Feedback-Sitzung</h2>
            <p style="color: var(--text-muted);">Starten Sie eine Live-Feedback-Runde für Ihre aktuelle Stunde.</p>
        </div>
        {% if active_session %}
            <span class="badge" style="background-color: var(--success-color); color: white; padding: 5px 10px; border-radius: 4px;">Sitzung Aktiv</span>
        {% endif %}
    </div>

    {% if active_session %}
        <div style="display: flex; gap: 30px; align-items: center; background: #f9f9f9; padding: 20px; border-radius: 8px;">
            <div style="text-align: center;">
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={{ (host_url ~ '/student_feedback.php?t=' ~ active_session.token)|url_encode }}" 
                     alt="QR Code" 
                     style="border: 10px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.1); cursor: pointer; transition: transform 0.2s;"
                     onclick="openQRModal()"
                     onmouseover="this.style.transform='scale(1.05)'"
                     onmouseout="this.style.transform='scale(1)'">
                <div style="margin-top: 10px; font-size: 0.8em; color: var(--text-muted);">Großansicht (Klick)</div>
            </div>
            <div style="flex: 1;">
                <h3 style="margin: 0 0 10px 0;">{{ active_session.klasse }} - {{ active_session.fach }}</h3>
                <p style="margin: 0 0 20px 0; font-size: 0.9em;">Schüler können jetzt unter folgendem Link abstimmen:</p>
                <code style="display: block; background: #eee; padding: 10px; border-radius: 4px; margin-bottom: 20px; font-size: 0.8em;">{{ host_url }}/student_feedback.php?t={{ active_session.token }}</code>
                
                <form action="/feedback_action.php" method="POST">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="action" value="stop">
                    <button type="submit" class="btn btn-danger" style="background-color: var(--danger-color); color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer;">Sitzung Beenden</button>
                    <a href="/feedback_view.php?id={{ active_session.id }}" class="btn" style="margin-left: 10px; text-decoration: none; color: var(--primary-color); border: 1px solid var(--primary-color); padding: 9px 20px; border-radius: 4px;">Ergebnisse ansehen</a>
                </form>
            </div>
        </div>
    {% else %}
        <form action="/feedback_action.php" method="POST" style="background: #f9f9f9; padding: 25px; border-radius: 8px;">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="action" value="start">
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px;">
                <div class="form-group" style="margin: 0;">
                    <label for="klasse-select" style="display: block; margin-bottom: 8px; font-weight: 600;">Klasse</label>
                    <select id="klasse-select" name="klasse" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 6px; background-color: white;">
                        <option value="">Bitte wählen</option>
                        {% if selected_class_ids|length > 0 %}
                            <optgroup label="Meine Klassen">
                                {% for c in all_classes %}
                                    {% if c.id in selected_class_ids %}
                                        <option value="{{ c.name }}">{{ c.name }}</option>
                                    {% endif %}
                                {% endfor %}
                            </optgroup>
                            <optgroup label="Alle Klassen">
                                {% for c in all_classes %}
                                    <option value="{{ c.name }}">{{ c.name }}</option>
                                {% endfor %}
                            </optgroup>
                        {% else %}
                            {% for c in all_classes %}
                                <option value="{{ c.name }}">{{ c.name }}</option>
                            {% endfor %}
                        {% endif %}
                    </select>
                </div>
                <div class="form-group" style="margin: 0;">
                    <label for="fach-input" style="display: block; margin-bottom: 8px; font-weight: 600;">Fach</label>
                    <input type="text" id="fach-input" name="fach" placeholder="z.B. Mathe" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 6px;">
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 25px;">
                <label for="template-select" style="display: block; margin-bottom: 8px; font-weight: 600;">Vorlage laden</label>
                <select id="template-select" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 6px; background-color: white;">
                    <option value="default" data-klasse="" data-fach="" data-questions='["Wie war die heutige Stunde?", "Wie ist aktuell das Klassenklima?"]'>Standard-Fragen (2 Fragen)</option>
                    <option value="empty" data-klasse="" data-fach="" data-questions='[]'>Leere Fragenliste</option>
                    {% for t in templates %}
                        <option value="{{ t.id }}" data-klasse="{{ t.klasse|escape('html_attr') }}" data-fach="{{ t.fach|escape('html_attr') }}" data-questions="{{ t.questions|json_encode|escape('html_attr') }}">{{ t.title }} ({{ t.question_count }} {{ t.question_count == 1 ? 'Frage' : 'Fragen' }})</option>
                    {% endfor %}
                </select>
            </div>

            <div id="questions-container" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 12px; font-weight: 600;">Fragen festlegen</label>
                <div class="question-row" style="display: flex; gap: 10px; margin-bottom: 10px;">
                    <input type="text" name="questions[]" value="Wie war die heutige Stunde?" aria-label="Frage" required style="flex: 1; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
                    <button type="button" onclick="this.parentElement.remove()" aria-label="Frage löschen" style="background: #ff7675; color: white; border: none; padding: 0 15px; border-radius: 6px; cursor: pointer;">✕</button>
                </div>
                <div class="question-row" style="display: flex; gap: 10px; margin-bottom: 10px;">
                    <input type="text" name="questions[]" value="Wie ist aktuell das Klassenklima?" aria-label="Frage" required style="flex: 1; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
                    <button type="button" onclick="this.parentElement.remove()" aria-label="Frage löschen" style="background: #ff7675; color: white; border: none; padding: 0 15px; border-radius: 6px; cursor: pointer;">✕</button>
                </div>
            </div>

            <button type="button" onclick="addQuestion()" style="background: #eee; border: 1px dashed #ccc; width: 100%; padding: 10px; border-radius: 6px; cursor: pointer; margin-bottom: 25px; color: #666;">+ Weitere Frage hinzufügen</button>

            <div style="margin-bottom: 25px; padding: 15px; background: #fff; border: 1px solid #eee; border-radius: 6px;">
                <label for="save-as-template-checkbox" style="display: flex; align-items: center; gap: 10px; cursor: pointer; font-weight: 600;">
                    <input type="checkbox" id="save-as-template-checkbox" name="save_template" value="1" onchange="toggleTemplateTitle(this.checked)">
                    <span>Aktuelle Fragen als Vorlage speichern</span>
                </label>
                <div id="template-title-container" style="display: none; margin-top: 15px;">
                    <label for="template-title-input" style="display: block; margin-bottom: 8px; font-size: 0.9em; color: var(--text-muted);">Name der Vorlage</label>
                    <input type="text" name="template_title" id="template-title-input" placeholder="z.B. Feedback zum Projektunterricht" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
                </div>
            </div>

            <div style="text-align: right;">
                <button type="submit" class="btn btn-primary" style="background-color: var(--primary-color); color: white; border: none; padding: 12px 30px; border-radius: 6px; cursor: pointer; font-weight: 600;">Sitzung erstellen & QR-Code generieren</button>
            </div>
        </form>
    {% endif %}
</div>

{% if templates is not empty %}
<div class="content-box" style="margin-top: 30px;">
    <h3 style="margin-top: 0;">Meine Vorlagen verwalten</h3>
    <p style="color: var(--text-muted); font-size: 0.9em; margin-bottom: 15px;">Hier können Sie Ihre gespeicherten Vorlagen löschen.</p>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px;">
        {% for t in templates %}
            <div style="background: #f9f9f9; padding: 15px; border-radius: 8px; border: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <strong style="display: block; color: var(--text-dark);">{{ t.title }}</strong>
                    <span style="font-size: 0.85em; color: var(--text-muted);">{{ t.question_count }} {{ t.question_count == 1 ? 'Frage' : 'Fragen' }}</span>
                </div>
                <form action="/feedback_action.php" method="POST" onsubmit="return confirm('Möchten Sie diese Vorlage wirklich löschen?');" style="margin: 0;">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="action" value="delete_template">
                    <input type="hidden" name="template_id" value="{{ t.id }}">
                    <button type="submit" class="btn-danger" style="background-color: var(--danger-color); color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 0.85em;">Löschen</button>
                </form>
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{% if active_session %}
<div id="qrModal" class="qr-modal" onclick="closeQRModal()">
    <button class="close-modal" onclick="closeQRModal()" aria-label="Schließen">&times;</button>
    <div class="qr-modal-content" onclick="event.stopPropagation()">
        <h2 style="margin-top: 0; color: var(--primary-color);">{{ active_session.klasse }} - {{ active_session.fach }}</h2>
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=500x500&data={{ (host_url ~ '/student_feedback.php?t=' ~ active_session.token)|url_encode }}" class="qr-large" alt="QR Code Large">
        <p style="margin-top: 20px; font-weight: 600; font-size: 1.2em;">Scan mich für Feedback!</p>
        <code style="display: block; background: #f0f0f0; padding: 10px; border-radius: 4px; font-size: 0.9em; margin-top: 10px;">{{ host_url }}/student_feedback.php?t={{ active_session.token }}</code>
    </div>
</div>
{% endif %}

{% endblock %}

{% block extra_scripts %}
<script>
function addQuestion() {
    addQuestionWithText('');
}

function addQuestionWithText(text = '') {
    const container = document.getElementById('questions-container');
    if (!container) return;
    const div = document.createElement('div');
    div.className = 'question-row';
    div.style.display = 'flex';
    div.style.gap = '10px';
    div.style.marginBottom = '10px';
    div.innerHTML = `
        <input type="text" name="questions[]" value="${escapeHtml(text)}" placeholder="Eigene Frage eingeben..." aria-label="Frage" required style="flex: 1; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
        <button type="button" onclick="this.parentElement.remove()" aria-label="Frage löschen" style="background: #ff7675; color: white; border: none; padding: 0 15px; border-radius: 6px; cursor: pointer;">✕</button>
    `;
    container.appendChild(div);
}

function escapeHtml(str) {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
}

function toggleTemplateTitle(checked) {
    const container = document.getElementById('template-title-container');
    const input = document.getElementById('template-title-input');
    if (container && input) {
        container.style.display = checked ? 'block' : 'none';
        input.required = checked;
        if (!checked) input.value = '';
    }
}

document.addEventListener("DOMContentLoaded", function() {
    const templateSelect = document.getElementById('template-select');
    if (templateSelect) {
        templateSelect.addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            
            // Populate class and subject
            const klasse = selectedOption.getAttribute('data-klasse') || '';
            const fach = selectedOption.getAttribute('data-fach') || '';
            const klasseSelect = document.querySelector('select[name="klasse"]');
            const fachInput = document.querySelector('input[name="fach"]');
            
            if (klasseSelect && klasse !== '') {
                klasseSelect.value = klasse;
            }
            if (fachInput && fach !== '') {
                fachInput.value = fach;
            }
            
            // Populate questions
            const questionsJson = selectedOption.getAttribute('data-questions');
            const questions = JSON.parse(questionsJson || '[]');
            
            const container = document.getElementById('questions-container');
            if (container) {
                // Remove all current question-row elements
                const rows = container.querySelectorAll('.question-row');
                rows.forEach(row => row.remove());
                
                if (questions.length === 0) {
                    addQuestionWithText(''); // At least one empty row
                } else {
                    questions.forEach(qText => {
                        addQuestionWithText(qText);
                    });
                }
            }
        });
    }
});

function openQRModal() {
    const modal = document.getElementById('qrModal');
    if (modal) {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
    }
}

function closeQRModal() {
    const modal = document.getElementById('qrModal');
    if (modal) {
        modal.classList.remove('active');
        document.body.style.overflow = 'auto';
    }
}

document.addEventListener('keydown', function(event) {
    if (event.key === "Escape") {
        closeQRModal();
    }
});
</script>
{% endblock %}
