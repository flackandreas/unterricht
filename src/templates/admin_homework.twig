{% extends "base.twig" %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <h1>Hausaufgaben (KI-Auswertung)</h1>
    <a href="/admin_dashboard.php" class="btn" style="text-decoration: none; border: 1px solid var(--border-color); color: var(--text-dark); padding: 8px 16px; border-radius: 4px;">Zurück zum Dashboard</a>
</div>

<div style="margin-bottom: 25px;">
    <details style="background: #f8fafc; border: 1px solid var(--border-color); border-radius: 6px; padding: 15px; cursor: pointer;">
        <summary style="font-weight: 600; color: var(--primary-color); outline: none;">ℹ️ Wie funktioniert die KI-Auswertung? (Hier klicken)</summary>
        <div style="margin-top: 15px; font-size: 0.95em; color: var(--text-dark); line-height: 1.5; cursor: default;">
            <p style="margin-top: 0;"><strong>Vorteile für Lehrkräfte & Schüler:</strong></p>
            <ul style="margin-bottom: 0;">
                <li><strong>Zeitersparnis:</strong> Du musst nicht mehr Dutzende von Hausaufgaben einzeln durchsehen. Die KI analysiert die eingereichten Fotos in Sekundenschnelle.</li>
                <li><strong>Gezielte Förderung:</strong> Du erhältst pro Einreichung sofort eine kurze Zusammenfassung der fachlichen Fehler und Lernschwierigkeiten. So kannst du in der nächsten Stunde direkt auf die Probleme der Klasse eingehen.</li>
                <li><strong>Individuelles Feedback:</strong> Jeder Schüler bekommt direkt nach dem Hochladen ein ermutigendes, konstruktives Feedback zur eigenen Lösung, was die Eigenverantwortung und Motivation deutlich steigert.</li>
                <li><strong>Datenschutz (DSGVO):</strong> Die Klarnamen der Schüler bleiben auf dem Schulserver. Sie werden durch ein Pseudonym ersetzt, bevor das Bild zur Auswertung an die KI (Google Gemini) gesendet wird.</li>
            </ul>
        </div>
    </details>
</div>

<div class="content-box" style="margin-bottom: 30px; border-top: 4px solid #2ecc71;">
    <h2 style="margin-top: 0;">Neue Hausaufgabe erstellen</h2>
    <form action="/admin_homework.php?action=create" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 15px;">
            <div class="form-group" style="margin: 0;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600;">Klasse</label>
                <select name="klasse" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; background-color: white;">
                    <option value="">Bitte wählen</option>
                    {% if selected_class_ids|length > 0 %}
                        <optgroup label="Meine Klassen">
                            {% for c in all_classes %}
                                {% if c.id in selected_class_ids %}
                                    <option value="{{ c.name }}">{{ c.name }}</option>
                                {% endif %}
                            {% endfor %}
                        </optgroup>
                        <optgroup label="Alle Klassen">
                            {% for c in all_classes %}
                                <option value="{{ c.name }}">{{ c.name }}</option>
                            {% endfor %}
                        </optgroup>
                    {% else %}
                        {% for c in all_classes %}
                            <option value="{{ c.name }}">{{ c.name }}</option>
                        {% endfor %}
                    {% endif %}
                </select>
            </div>
            <div class="form-group" style="margin: 0;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600;">Fach</label>
                <input type="text" name="fach" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
            </div>
            <div class="form-group" style="margin: 0;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600;">Erwartete Abgaben</label>
                <input type="number" name="expected_submissions" min="0" value="25" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
            </div>
        </div>

        <div class="form-group" style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 8px; font-weight: 600;">Titel der Hausaufgabe</label>
            <input type="text" name="title" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" placeholder="z.B. S. 14 Nr. 3a">
        </div>

        <div class="form-group" style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 8px; font-weight: 600;">Aufgabenstellung / Kontext für die KI</label>
            <textarea name="description" required rows="4" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" placeholder="Beschreibe kurz die Aufgabe, damit die KI weiß, worauf sie bei der Auswertung achten muss..."></textarea>
        </div>

        <div class="form-group" style="margin-bottom: 25px;">
            <label style="display: block; margin-bottom: 8px; font-weight: 600;">Kontext-Bild (Lösung, Muster oder Aufgabenblatt)</label>
            <input type="file" name="context_image" accept="image/*" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; background: #fff;">
            <p style="color: var(--text-muted); font-size: 0.85em; margin-top: 5px;">Optional: Ein Bild der Musterlösung hilft der KI, die Schülerantworten präziser zu bewerten.</p>
        </div>

        <div style="text-align: right;">
            <button type="submit" class="btn btn-primary" style="background-color: #2ecc71; color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer; font-weight: 600;">Hausaufgabe erstellen</button>
        </div>
    </form>
</div>

<div class="content-box">
    <h2 style="margin-top: 0;">Aktive & Vergangene Hausaufgaben</h2>
    
    {% if assignments is empty %}
        <p style="color: var(--text-muted);">Es wurden noch keine Hausaufgaben erstellt.</p>
    {% else %}
        <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-color); text-align: left;">
                    <th style="padding: 12px;">Erstellt am</th>
                    <th style="padding: 12px;">Klasse / Fach</th>
                    <th style="padding: 12px;">Titel</th>
                    <th style="padding: 12px;">Einreichungen</th>
                    <th style="padding: 12px; text-align: right;">Aktion</th>
                </tr>
            </thead>
            <tbody>
                {% for assignment in assignments %}
                <tr style="border-bottom: 1px solid var(--border-color);">
                    <td style="padding: 12px;">{{ assignment.created_at|date('d.m.Y') }}</td>
                    <td style="padding: 12px;"><strong>{{ assignment.klasse }}</strong> - {{ assignment.fach }}</td>
                    <td style="padding: 12px;">{{ assignment.title }}</td>
                    <td style="padding: 12px;">
                        <span class="badge" style="background-color: var(--primary-color); color: white; padding: 4px 8px; border-radius: 12px;">{{ assignment.submission_count }}</span>
                    </td>
                    <td style="padding: 12px; text-align: right; white-space: nowrap;">
                        <a href="/admin_homework.php?action=view&id={{ assignment.id }}" class="btn" style="background-color: #f1f5f9; color: var(--primary-color); padding: 6px 12px; border-radius: 4px; text-decoration: none; font-size: 0.9em; display: inline-block;">Ergebnisse & Link</a>
                        <button type="button" class="button-danger btn-delete-assignment" data-id="{{ assignment.id }}" style="padding: 6px 12px; font-size: 0.9em; border-radius: 4px; margin-left: 5px; display: inline-block;">Löschen</button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>

<!-- Grouped Submissions Section -->
<div class="content-box" style="margin-top: 30px;">
    <h2 style="margin-top: 0; margin-bottom: 20px;">Eingegangene Einreichungen (nach Hausaufgabe gruppiert)</h2>
    
    {% set has_any_submissions = false %}
    {% for assignment in assignments %}
        {% if assignment.submissions is not empty %}
            {% set has_any_submissions = true %}
            
            <div class="content-box" style="border-left: 4px solid var(--primary-color); margin-bottom: 25px; background-color: var(--bg-main); padding: 20px; border-radius: 8px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; flex-wrap: wrap; gap: 10px;">
                    <h3 style="margin: 0; font-size: 1.15em;">{{ assignment.klasse }} - {{ assignment.fach }}: <span style="color: var(--primary-color);">{{ assignment.title }}</span></h3>
                    <a href="/admin_homework.php?action=view&id={{ assignment.id }}" class="button-secondary" style="padding: 6px 12px; font-size: 0.85em; text-decoration: none; display: inline-block;">Ergebnisse ansehen & Link teilen</a>
                </div>
                
                <form action="/admin_homework.php?action=delete_submissions_bulk" method="POST" class="bulk-delete-form-{{ assignment.id }}" style="margin: 0;">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="assignment_id" value="">
                    
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; background: var(--bg-content); padding: 10px 15px; border-radius: 6px; border: 1px solid var(--border-color);">
                        <label style="display: flex; align-items: center; font-weight: 600; cursor: pointer; user-select: none; margin: 0; font-size: 0.95em;">
                            <input type="checkbox" class="select-all-checkbox" data-target="{{ assignment.id }}" style="margin-right: 8px; width: 18px; height: 18px; cursor: pointer;">
                            Alle auswählen
                        </label>
                        <button type="submit" class="button-danger bulk-delete-btn" data-target="{{ assignment.id }}" style="padding: 6px 12px; font-size: 0.85em; display: none; font-weight: 600;" onclick="return confirmBulkDelete(event, '{{ assignment.id }}')">Ausgewählte löschen</button>
                    </div>

                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px;">
                        {% for sub in assignment.submissions %}
                            <div class="content-box" style="padding: 15px; margin: 0; background: var(--bg-content); display: flex; flex-direction: column; justify-content: space-between; border-radius: 8px; border: 1px solid var(--border-color); box-shadow: var(--shadow-soft);">
                                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px;">
                                    <label style="display: flex; align-items: flex-start; cursor: pointer; user-select: none; font-weight: 600; margin: 0; max-width: 70%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <input type="checkbox" name="submission_ids[]" value="{{ sub.id }}" class="sub-checkbox-{{ assignment.id }}" data-assignment="{{ assignment.id }}" style="margin-right: 8px; width: 18px; height: 18px; cursor: pointer; margin-top: 1px; flex-shrink: 0;">
                                        {{ sub.student_name }}
                                    </label>
                                    <span style="font-size: 0.75em; color: var(--text-muted); flex-shrink: 0;">{{ sub.created_at|date('d.m.Y H:i') }}</span>
                                </div>
                                <div style="display: flex; gap: 12px; align-items: center; margin-top: 5px;">
                                    <a href="/{{ sub.image_path }}" target="_blank" style="display: block; width: 55px; height: 55px; background-image: url('/{{ sub.image_path }}'); background-size: cover; background-position: center; border-radius: 4px; border: 1px solid var(--border-color); flex-shrink: 0;" title="Bild in neuem Tab öffnen"></a>
                                    <div style="flex-grow: 1; min-width: 0; overflow: hidden;">
                                        <span style="font-size: 0.8em; display: block; color: var(--text-muted); text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">Status: {% if sub.status == 'evaluated' %}Ausgewertet{% else %}In Warteschlange{% endif %}</span>
                                        {% if sub.score is not null %}
                                            <strong style="color: var(--primary-color); font-size: 0.9em; display: block; margin-top: 2px;">Punkte: {{ sub.score }}</strong>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </form>
            </div>
        {% endif %}
    {% endfor %}
    
    {% if not has_any_submissions %}
        <p style="color: var(--text-muted); text-align: center; padding: 20px; margin: 0;">Bisher wurden noch keine Hausaufgaben von Schülern eingereicht.</p>
    {% endif %}
    
    <form id="delete-assignment-form" action="/admin_homework.php?action=delete_assignment" method="POST" style="display: none;">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <input type="hidden" name="assignment_id" id="delete-assignment-id" value="">
    </form>
</div>
{% endblock %}

{% block extra_scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    // Delete Assignment Handler
    document.querySelectorAll('.btn-delete-assignment').forEach(btn => {
        btn.addEventListener('click', function(e) {
            const id = this.dataset.id;
            Swal.fire({
                title: 'Hausaufgabe löschen?',
                text: "Diese Aktion löscht die Hausaufgabe, alle Schüler-Einreichungen (Bilder) und alle Bewertungen unwiderruflich!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: 'var(--danger-color)',
                cancelButtonColor: 'var(--text-muted)',
                confirmButtonText: 'Ja, alles löschen',
                cancelButtonText: 'Abbrechen'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('delete-assignment-id').value = id;
                    document.getElementById('delete-assignment-form').submit();
                }
            });
        });
    });

    // Select All Checkbox Handler
    document.querySelectorAll('.select-all-checkbox').forEach(selectAll => {
        selectAll.addEventListener('change', function() {
            const assignmentId = this.dataset.target;
            const checkBoxes = document.querySelectorAll('.sub-checkbox-' + assignmentId);
            checkBoxes.forEach(cb => cb.checked = this.checked);
            updateBulkDeleteButtonVisibility(assignmentId);
        });
    });

    // Individual Checkbox Handler
    document.querySelectorAll('[class^="sub-checkbox-"]').forEach(cb => {
        cb.addEventListener('change', function() {
            const assignmentId = this.dataset.assignment;
            const selectAll = document.querySelector('.select-all-checkbox[data-target="' + assignmentId + '"]');
            const total = document.querySelectorAll('.sub-checkbox-' + assignmentId).length;
            const checked = document.querySelectorAll('.sub-checkbox-' + assignmentId + ':checked').length;
            if (selectAll) {
                selectAll.checked = (total === checked);
            }
            updateBulkDeleteButtonVisibility(assignmentId);
        });
    });

    function updateBulkDeleteButtonVisibility(assignmentId) {
        const checkedCount = document.querySelectorAll('.sub-checkbox-' + assignmentId + ':checked').length;
        const btn = document.querySelector('.bulk-delete-btn[data-target="' + assignmentId + '"]');
        if (btn) {
            btn.style.display = checkedCount > 0 ? 'inline-block' : 'none';
        }
    }
});

function confirmBulkDelete(event, assignmentId) {
    event.preventDefault();
    const form = document.querySelector('.bulk-delete-form-' + assignmentId);
    const checkedCount = document.querySelectorAll('.sub-checkbox-' + assignmentId + ':checked').length;
    
    if (checkedCount === 0) return false;

    Swal.fire({
        title: checkedCount + ' Einreichung(en) löschen?',
        text: "Diese Aktion kann nicht rückgängig gemacht werden. Die hochgeladenen Bilder und Bewertungen werden endgültig gelöscht.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: 'var(--danger-color)',
        cancelButtonColor: 'var(--text-muted)',
        confirmButtonText: 'Ja, löschen',
        cancelButtonText: 'Abbrechen'
    }).then((result) => {
        if (result.isConfirmed) {
            form.submit();
        }
    });
    return false;
}
</script>
{% endblock %}
